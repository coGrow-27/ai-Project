USE_MOCK=True
LLM_PROVIDER=mock
INFLUENCER_PROVIDER=rapidapi

# Campaign 结果：展示 Top 10，仅 Top 5 生成完整文案
CAMPAIGN_TOP_K=10
CONTENT_TOP_K=5

# RapidAPI 红人检索（USE_MOCK=False 时启用，失败自动降级 Mock）
RAPID_API_KEY=your_rapidapi_key_here
RAPID_API_HOST=influencer-data1.p.rapidapi.com

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

REDIS_URL=redis://localhost:6379/0

# PostgreSQL persistence. Local tests may use sqlite:///./data/ai_influencer.db
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ai_influencer_rag
DB_AUTO_CREATE=False

BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:8000","http://127.0.0.1:8000"]
